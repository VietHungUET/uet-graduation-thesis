model PaperResearch

-- Classes
class Paper
attributes
  title : String
  wordCount : Integer
  studentPaper : Boolean
operations
  newPaper(title : String, wc : Integer, sp : Boolean) : Paper
end

class Researcher
attributes
  name : String
  isStudent : Boolean
end

-- Associations
association Reviews between
  Researcher[3..3] role referee
  Paper[1] role submission
end

association Writes between
  Researcher[1..2] role author
  Paper[1] role manuscript
end

-- Constraints
constraints

-- Authors of student papers must include at least one student
context Paper inv AuthorsOfStudentPaper:
  self.studentPaper = self.author->exists(x | x.isStudent)

-- There must be at least one student paper, but fewer than 5
context Paper inv LimitsOnStudentPapers:
  Paper.allInstances()->exists(p | p.studentPaper) and 
  Paper.allInstances()->select(p | p.studentPaper)->size() < 5

-- Papers must be less than 10000 words
context Paper inv PaperLength:
  self.wordCount < 10000

-- Researchers cannot review their own papers
context Researcher inv NoSelfReviews:
  self.submission->excludes(self.manuscript)

-- Student researchers cannot be referees
context Paper inv NoStudentReviewers:
  self.referee->forAll(r | not r.isStudent)
