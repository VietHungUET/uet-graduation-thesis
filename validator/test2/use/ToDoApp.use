--------------------------------------------------------------- ToDoApp
model ToDoApp

----------------------------------------------------------------- class User
class User
attributes
  name : String -- key
end

----------------------------------------------------------------- class Task
class Task
attributes
  title : String -- key
  priority : Integer
end

--------------------------------------------------------------- class Project
class Project
attributes
  name : String -- key
  taskList : Sequence(Task)
end

--------------------------------------------------------- association Owns
association Owns between
  User[1] role owner
  Project[0..*] role project
end

association Contains between
  Project[1] role project
  Task[0..*] role tasks ordered
end

---------------------------s--------------------------------- constraints
constraints

------------------------------------------------------------ User constraints
-- context u:User inv nameNotEmpty:
--   u.name <> '' and u.name <> oclUndefined(String)

-- context u1:User inv uniqueUserName:
--   User.allInstances->forAll(u2 | u1 <> u2 implies u1.name <> u2.name)


----------------------------------------------------------- Task constraints
-- context t:Task inv titleNotEmpty:
--   t.title <> '' and t.title <> oclUndefined(String)

-- context t1:Task inv titleIsUnique:
--   Task.allInstances->forAll(t2 | t1 <> t2 implies t1.title <> t2.title)

-- Mỗi Task phải có priority khác nhau
context t1:Task inv uniquePriority:
  Task.allInstances->forAll(t2 | t1 <> t2 implies t1.priority <> t2.priority)


---------------------------------------------------------- Project constraints


context p:Project inv firstTaskIsLowestPriority:
  p.taskList->size() > 0 implies
  p.taskList->first().priority = 
     p.taskList->collect(t | t.priority)->min()

-- 2. last(): Task cuối cùng phải có priority lớn nhất
context p:Project inv lastTaskIsHighestPriority:
  p.taskList->size() > 0 implies
  p.taskList->last().priority = 
     p.taskList->collect(t | t.priority)->max()

